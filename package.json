{
  "name": "careerforge",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install:all": "npm install --prefix backend && npm install --prefix frontend",
    "seed": "npm run seed --prefix backend",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:ai": "cd ai-service && python -m uvicorn main:app --reload --host 127.0.0.1 --port 8000",
    "dev:all": "powershell -ExecutionPolicy Bypass -File ./start.ps1",
    "start:backend": "npm start --prefix backend",
    "start:frontend": "npm start --prefix frontend",
    "start:ai": "cd ai-service && python -m uvicorn main:app --host 127.0.0.1 --port 8000",
    "start:all": "powershell -ExecutionPolicy Bypass -File ./start.ps1",
    "build": "npm run build --prefix frontend"
  }
}
